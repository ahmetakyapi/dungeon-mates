{
  "name": "dungeon-mates",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "next dev --turbo -p 3002",
    "dev:server": "tsx watch server/index.ts",
    "build": "next build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "next start",
    "start:server": "node dist/server/index.js"
  },
  "dependencies": {
    "next": "^14.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "socket.io": "^4.7.0",
    "socket.io-client": "^4.7.0",
    "framer-motion": "^11.0.0",
    "tailwindcss": "^3.4.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.0",
    "postcss": "^8.4.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
